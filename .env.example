DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
BETTER_AUTH_SECRET=your_32_cAAAAAAAAAAAharacter_base64_secret_here # Generate with: openssl rand -base64 32
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:5001

NEXT_PUBLIC_BACKEND_URL=http://localhost:5001
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Inngest (durable background jobs & workflows)
# Local dev needs NONE of these — run the Dev Server: pnpm inngest:dev
# Only required against Inngest Cloud (production):
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Optional overrides:
# INNGEST_APP_ID=codesetu
# INNGEST_DEV=1   # force dev mode (1) or cloud mode (0)

# Email — Nodemailer over Resend SMTP (used by the welcome-email function)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Codesetu <onboarding@resend.dev>
# Optional SMTP overrides (defaults: smtp.resend.com:465):
# RESEND_SMTP_HOST=smtp.resend.com
# RESEND_SMTP_PORT=465

# AI providers (model picker / pipeline). Each is OPTIONAL — a provider with no
# key is simply hidden from the model catalog. Set at least one to run a pipeline.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=   # free models live here (https://openrouter.ai/keys)

